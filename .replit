modules = ["nodejs-20", "web"]

[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["psmisc"]

[deployment]
deploymentTarget = "autoscale"
# Deployment ke liye 3000 port hi fix rakhte hain
run = [
  "sh",
  "-c",
  "npm run build && npx vite preview --host 0.0.0.0 --port 3000",
]
build = ["npm", "run", "build"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
# Isse Replit ko pata chalega ki app 3000 par ready hogi
waitForPort = 3000

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 5001
externalPort = 3000

